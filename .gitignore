# =========================================================
# BACKEND + FRONTEND (USER + ADMIN) COMBINED .gitignore
# =========================================================


# ===========================
# Node modules (all projects)
# ===========================
node_modules/


# ===========================
# Environment files
# ===========================
.env
.env.*
!.env.example
*.local


# ===========================
# Logs
# ===========================
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*


# ===========================
# Diagnostic reports
# ===========================
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json


# ===========================
# Runtime data
# ===========================
pids
*.pid
*.seed
*.pid.lock


# ===========================
# jscoverage / JSCover
# ===========================
lib-cov


# ===========================
# Coverage
# ===========================
coverage
*.lcov
.nyc_output


# ===========================
# Grunt
# ===========================
.grunt


# ===========================
# Bower
# ===========================
bower_components


# ===========================
# node-waf
# ===========================
.lock-wscript


# ===========================
# Compiled addons
# ===========================
build/Release


# ===========================
# Dependency directories
# ===========================
jspm_packages/
web_modules/


# ===========================
# TypeScript
# ===========================
*.tsbuildinfo


# ===========================
# Optional caches & history
# ===========================
.npm
.eslintcache
.stylelintcache
.node_repl_history


# ===========================
# NPM pack output
# ===========================
*.tgz


# ===========================
# Yarn v1/v2/v3
# ===========================
.yarn-integrity
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/sdks
!.yarn/versions


# ===========================
# Parcel cache
# ===========================
.cache
.parcel-cache


# ===========================
# Next.js
# ===========================
.next
out


# ===========================
# Nuxt.js
# ===========================
.nuxt
dist
.output


# ===========================
# Gatsby
# ===========================
.cache/


# ===========================
# Vuepress
# ===========================
.vuepress/dist
.temp
.cache


# ===========================
# SvelteKit
# ===========================
.svelte-kit/


# ===========================
# VitePress
# ===========================
**/.vitepress/dist
**/.vitepress/cache


# ===========================
# Docusaurus
# ===========================
.docusaurus


# ===========================
# Serverless
# ===========================
.serverless/


# ===========================
# FuseBox
# ===========================
.fusebox/


# ===========================
# DynamoDB Local
# ===========================
.dynamodb/


# ===========================
# Firebase
# ===========================
.firebase/


# ===========================
# TernJS
# ===========================
.tern-port


# ===========================
# VSCode test variants
# ===========================
.vscode-test


# ===========================
# Vite
# ===========================
vite.config.js.timestamp-*
vite.config.ts.timestamp-*
.vite/


# ===========================
# Editor settings (Frontend)
# ===========================
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?


# ===========================
# Build output (Frontend)
# ===========================
dist
dist-ssr
build/
